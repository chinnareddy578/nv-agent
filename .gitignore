# nv-agent .gitignore

# Environment / secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Data & indexes (generated at runtime)
data/sessions/
kb/index/

# Test artifacts
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Docker (local overrides)
docker-compose.override.yml

# Claude Code
.claude/
